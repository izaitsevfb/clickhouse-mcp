# ClickHouse connection settings
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# Optional: Disable temporary file generation for query results
# When set to 'true', query results are only returned inline (no tmp files created)
CLICKHOUSE_DISABLE_TMP_FILES=false

# Optional: Strip HTTP(S)_PROXY env vars on startup
# Enable this in corporate environments where a system-level proxy (e.g. x2pagentd)
# intercepts HTTPS traffic with a TLS library too old to negotiate with ClickHouse Cloud.
# Accepts: 1, true, yes
CLICKHOUSE_MCP_NO_PROXY=false
